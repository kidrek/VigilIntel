 'https://www.cve.org/CVERecord?id=CVE-2026-9110', 'https://www.cve.org/CVERecord?id=CVE-2026-9111', 'https://www.cve.org/CVERecord?id=CVE-2026-9112', 'https://www.cve.org/CVERecord?id=CVE-2026-9113', 'https://www.cve.org/CVERecord?id=CVE-2026-9114', 'https://www.cve.org/CVERecord?id=CVE-2026-9115', 'https://www.cve.org/CVERecord?id=CVE-2026-9116', 'https://www.cve.org/CVERecord?id=CVE-2026-9117', 'https://www.cve.org/CVERecord?id=CVE-2026-9118', 'https://www.cve.org/CVERecord?id=CVE-2026-9119', 'https://www.cve.org/CVERecord?id=CVE-2026-9120', 'https://www.cve.org/CVERecord?id=CVE-2026-9121', 'https://www.cve.org/CVERecord?id=CVE-2026-9122', 'https://www.cve.org/CVERecord?id=CVE-2026-9123', 'https://www.cve.org/CVERecord?id=CVE-2026-9124', 'https://www.cve.org/CVERecord?id=CVE-2026-9126'], 'vulnerability': ['CVE-2026-8564', 'CVE-2026-8574', 'CVE-2026-8583', 'CVE-2026-8520', 'CVE-2026-8521', 'CVE-2026-8522', 'CVE-2026-9110', 'CVE-2026-9111', 'CVE-2026-9112', 'CVE-2026-9113', 'CVE-2026-9114', 'CVE-2026-9115', 'CVE-2026-9116', 'CVE-2026-9117', 'CVE-2026-9118', 'CVE-2026-9119', 'CVE-2026-9120', 'CVE-2026-9121', 'CVE-2026-9122', 'CVE-2026-9123', 'CVE-2026-9124', 'CVE-2026-9126']}}, {'title': 'Vulnérabilité dans les produits Microsoft (22 mai 2026)', 'publication_date': 'Fri, 22 May 2026 00:00:00 +0000', 'source': 'https://www.cert.ssi.gouv.fr/avis/CERTFR-2026-AVI-0634/', 'source_type': "['operational', 'vulnerabilities']", 'source_level': 1, 'text': [], 'observables': {'domain-name': ['cve.org'], 'url': ['http://www.cve.org/CVERecord?id=CVE-2026-45659', 'https://msrc.microsoft.com/update-guide/vulnerability/CVE-2026-45659', 'https://www.cve.org/CVERecord?id=CVE-2026-45659'], 'vulnerability': ['CVE-2026-45659']}}, {'title': 'Vulnérabilité dans SPIP (22 mai 2026)', 'publication_date': 'Fri, 22 May 2026 00:00:00 +0000', 'source': 'https://www.cert.ssi.gouv.fr/avis/CERTFR-2026-AVI-0635/', 'source_type': "['operational', 'vulnerabilities']", 'source_level': 1, 'text': [], 'o