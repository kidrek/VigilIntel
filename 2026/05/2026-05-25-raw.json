rce_level': 2, 'text': [], 'observables': {'email-addr': ['NickAEsp@mastodon.social']}}, {'title': "Daily podcast: Caesars Entertainment, GitHub, Panasonic, 7-Eleven, NYC Health and a whole lot are all part of this week's insanity....#News #TechNews #Cybersecurity #Privacy #Databreach #Ransomware #podcasthttps://soundcloud.com/nickaesp/b2026-05-24", 'publication_date': 'Sun, 24 May 2026 21:27:57 +0000', 'source': 'https://mastodon.social/@NickAEsp/116631530736612623', 'source_type': "['']", 'source_level': 2, 'text': [], 'observables': {'domain-name': ['soundcloud.com'], 'email-addr': ['NickAEsp@mastodon.social']}}, {'title': '📰 NYC Health + Hospitals Breach May Affect 1.8 Million Patients and EmployeesMassive data breach at NYC Health + Hospitals may have compromised the personal and health information of 1.8 MILLION people. Patients and employees are affected, putting them at high risk of fraud. 🏥 #DataBreach #Healthcare #HIPAA #Privacy🌐 cyber[.]netsecops[.]io🔗 https://cyber.netsecops.io/articles/nyc-health-hospitals-reports-massive-data-breach-affecting-1-8-million/?utm_source=mast…', 'publication_date': 'Sun, 24 May 2026 17:31:47 +0000', 'source': 'https://mastodon.social/@netsecio/116630692108198612', 'source_type': "['']", 'source_level': 2, 'text': ['Massive data breach at NYC Health + Hospitals may have compromised the personal and health information of 1.8 MILLION people. Patients and employees are affected, putting them at high risk of fraud.#DataBreach#Healthcare#HIPAA#Privacy'], 'observables': {'domain-name': ['cyber.netsecops.io'], 'email-addr': ['netsecio@mastodon.social']}}, {'title': "📰 CISA Contractor Leaks AWS GovCloud Keys and Internal System Credentials on Public GitHub Repo‼️ MAJOR LAPSE: A CISA contractor leaked plaintext AWS GovCloud keys & internal system credentials on a public GitHub repo for months. The incident has sparked a congressional inquiry into the agency's security practices. #CISA #DataBreach #GovCloud🌐 cyber[.]netsecops[.]io🔗 https://cyber.netsecops.io/articles/cisa-contractor-leaks-govcloud-keys-on-public-github-sparking…", 'publication_date': 'Sun, 24 May 2026 17:31:47 +0000', 'source': 'https://mastodon.social/@netsecio/116630690828668033', 'source_type': "['']", 'source_level': 2, 'text': [], 'observables': {'domain-name': ['cyber.netsecops.io'], 'email-addr': ['netsecio@mastodon.social']}}, {'title': '📰 Trump Mobile API Flaw Exposes Personal Data of 27,000 Smartphone Pre-Order Customers⚠️ Trump Mobile confirms data leak affecting 27,000 T1 smartphone pre-orders. An unprotected API exposed customer names, addresses, and phone numbers. The company is investigating the security flaw. #DataBreach #APIsecurity #Privacy🌐 cyber[.]netsecops[.]io🔗 https://cyber.netsecops.io/articles/trump-mobile-investigates-data-leak-of-27000-pre-orders-after-unprotected-api-discovery…', 'publication_date': 'Sun, 24 May 2026 17:31:47 +0000', 'source': 'https://mastodon.social/@netsecio/116630690617266981', 'source_type': "['']", 'source_level': 2, 'text': [], 'observables': {'domain-name': ['cyber.netsecops.io'], 'email-addr': ['netsecio@mastodon.social']}}, {'title': '🛡 THREAT INTEL | University of Valencia🟢 Actor "nova" claims UndisclosedAllegedly exposed • Personal data⚠️ Unverified claimhttps://www.yazoul.net/intel/claim/2026-05-24-university-of-valencia-ransomware-attack-by-nova-may-2026#DarkWeb #DataBreach #ThreatIntel #CyberSecurity #InfoSec', 'publication_date': 'Sun, 24 May 2026 11:34:22 +0000', 'source': 'https://infosec.exchange/@Matchbook3469/116629273990997825', 'source_type': "['']", 'source_level': 2, 'text': [], 'observables': {'domain-name': ['yazoul.net']}}, {'title': '🛡 THREAT INTEL | Cablematic Dos Mil SLU🟢 Actor "gunra" claims Undisclosed⚠️ Unverified claimhttps://www.yazoul.net/intel/claim/2026-05-23-cablematic-ransomware-attack-by-gunra-may-2026#DarkWeb #DataBreach #ThreatIntel #CyberSecurity #InfoSec', 'publication_date': 'Sun, 24 May 2026 09:34:18 +0000', 'source': 'https://infosec.exchange/@Matchbook3469/116628817648219750', 'source_type': "['']", 'source_level': 2, 'text': [], 'observables': {'artifact': [], 'autonomous-system': [], 'directory': [], 'domain-name': [], 'email-addr': [], 'email-message': [], 'file': [], 'ipv4-addr': [], 'ipv6-addr': [], 'mac-addr': [], 'mutex': [], 'network-traffic': [], 'process': [], 'software': [], 'url': [], 'user-account': [], 'windows-registry-key': [], 'x509-certificate': [], 'vulnerability': [], 'mitre': []}}, {'title': '7-Eleven - 185,256 breached accounts', 'publication_date': 'Sun, 24 May 2026 05:15:22 Z', 'source': 'https://haveibeenpwned.com/Breach/7-Eleven', 'source_type': "['']", 'source_level': 2, 'text': ['In April 2026,7-Eleven was the victim of a "pay or leak" extortion campaign by ShinyHunters, with the data later published that month. The incident exposed 185k unique email addresses, along with names, physical addresses, dates of birth and phone numbers. A small number of records also contained additional exposed data fields. The company later advised the breach was limited to "certain 7-Eleven systems used to store franchisee documents", a statement consistent with the exposed data.'], 'observables': {}}]