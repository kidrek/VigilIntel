5b6-4588-a14c-a66105329b92"]}, {"type": "relationship", "spec_version": "2.1", "id": "relationship--99cb7aef-02be-53aa-9693-d9ab208a67cd", "created": "2026-05-16T00:00:00Z", "modified": "2026-05-16T00:00:00Z", "created_by_ref": "identity--1dc08bb0-1b9a-5415-b578-aacc99ac99ea", "relationship_type": "uses", "source_ref": "threat-actor--b47b65f6-52a4-5ead-beae-dce6e18046a3", "target_ref": "attack-pattern--3f99b747-d620-570f-aede-6c92127069e3", "labels": ["apt", "botnet", "p2p", "kazuar", "threat", "viglintel", "daily-report"], "object_marking_refs": ["marking-definition--613f2e26-407d-48c7-9eca-b8e91df99dc9", "marking-definition--ad15a0cd-55b6-4588-a14c-a66105329b92"]}, {"type": "note", "spec_version": "2.1", "id": "note--53284d5d-678e-5283-9378-b730b5a27d8f", "created": "2026-05-16T00:00:00Z", "modified": "2026-05-16T00:00:00Z", "created_by_ref": "identity--1dc08bb0-1b9a-5415-b578-aacc99ac99ea", "content": "## Summary\n**FR:** L'acteur de menace russe Turla a converti sa backdoor Kazuar en un botnet P2P modulaire dot\u00e9 de m\u00e9canismes de furtivit\u00e9 avanc\u00e9s tels que l'IPC chiffr\u00e9 et des n\u0153uds 'Bridge' internes.\n\n**EN:** The Russian threat actor Turla has converted its Kazuar backdoor into a modular P2P botnet featuring advanced stealth mechanisms like encrypted IPC and internal 'Bridge' nodes.\n\n## Actor / Campaign / Malware / TTPs / Tools\n- Threat actor: Turla\n- Intrusion set: (unknown)\n- Campaign: (unknown)\n- Malware: (none)\n- MITRE TTPs: T1071, T1573.002, T1543, T1014\n- Tools: Kazuar, Protobuf\n\n## Analysis\n**FR:** Kazuar utilise une architecture de type 'leader' pour masquer l'activit\u00e9 r\u00e9seau ; seul un syst\u00e8me communique avec l'ext\u00e9rieur tandis que les autres s'\u00e9changent des ordres via IPC chiffr\u00e9. Il cible l'espionnage \u00e0 long terme via la capture d'\u00e9cran, le keylogging et le vol de documents.\n\n**EN:** Kazuar uses a 'leader' architecture to hide network activity; only one system communicates externally while others exchange orders via encrypted IPC. It targets long-term espionage through screenshot capture, keylogging, and document theft.\n\n## Recommendations\n- **[FR]:** Surveiller les flux RPC/IPC internes inhabituels\n\n  **[EN]:** Monitor for unusual internal RPC/IPC flows\n- **[FR]:** D\u00e9ployer des solutions EDR capables d'analyser l'injection de processus\n\n  **[EN]:** Deploy EDR solutions capable of process injection analysis\n\n## Indicators (defanged)\n- URLs: (none)\n- Domains: (none)\n- IPv4: (none)\n- IPv6: (none)\n- Emails: (none)\n- Hashes: (none)\n\n## Infrastructure\n(none)\n\n## Tags\napt, botnet, p2p, kazuar\n\n## Sources\n- hxxps://www[.]bleepingcomputer[.]com/news/security/russian-hackers-turn-kazuar-backdoor-into-modular-p2p-botnet/\n", "object_refs": ["threat-actor--b47b65f6-52a4-5ead-beae-dce6e18046a3", "tool--1ab313d8-d65f-5716-9696-3bf5be9ce7e3", "tool--5fab1f40-5d9e-5ad2-983b-2befc7aeb04c", "attack-pattern--bfb7520a-fe2f-553b-8997-cd75e4b7752d", "attack-pattern--93d9afbb-950a-50fd-98ad-750c05000b94", "attack-pattern--41b0cc12-9702-518e-973c-a641bd278697", "attack-pattern--3f99b747-d620-570f-aede-6c92127069e3"], "abstract": "Threat | \u00c9volution du botnet Kazuar par Turla (2026-05-16)", "external_references": [{"source_name": "source", "url": "hxxps://www[.]bleepingcomputer[.]com/news/security/russian-hackers-turn-kazuar-backdoor-into-modular-p2p-botnet/"}], "labels": ["apt", "botnet", "p2p", "kazuar", "threat", "viglintel", "daily-report"], "object_marking_refs": ["marking-definition--613f2e26-407d-48c7-9eca-b8e91df99dc9", "marking-definition--ad15a0cd-55b6-4588-a14c-a66105329b92"]}, {"type": "relationship", "spec_version": "2.1", "id": "relationship--7f5c4bb7-ee3f-5a77-9ab9-abe22565a7d8", "created": "2026-05-16T00:00:00Z", "modified": "2026-05-16T00:00:00Z", "created_by_ref": "identity--1dc08bb0-1b9a-5415-b578-aacc99ac99ea", "relationship_type": "related-to", "source_ref": "note--53284d5d-678e-5283-9378-b730b5a27